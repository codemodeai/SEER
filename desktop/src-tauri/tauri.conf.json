{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SEER",
  "version": "1.0.0",
  "identifier": "ai.seer.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SEER",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["../agent/dist/index"],
    "macOS": {
      "urlSchemes": ["seer"]
    },
    "windows": {
      "urlSchemes": ["seer"]
    },
    "linux": {
      "urlSchemes": ["seer"]
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/codemodeai/seer/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  }
}
